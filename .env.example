# Public application configuration
APP_NAME=AI Orchestra
APP_VERSION=0.1.0
LOG_LEVEL=info
PORT=3000

# Governed execution mode (server-only): disabled, ollama_local, or judge_fixture.
# judge_fixture is provider-free deterministic test-only judge infrastructure.
AI_ORCHESTRA_EXECUTION_MODE=disabled

# Optional native-host Ollama live mode (server-only and loopback-only)
AI_ORCHESTRA_LOCAL_EXECUTION_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_ORCHESTRA_LOCAL_MODEL=qwen3:4b
AI_ORCHESTRA_LOCAL_TIMEOUT_MS=120000
AI_ORCHESTRA_LOCAL_MAX_OUTPUT_TOKENS=1024
AI_ORCHESTRA_MAX_TOTAL_TOKENS=12000
AI_ORCHESTRA_MAX_CONCURRENT_RUNS=2

# Optional future hosted provider (disabled by default)
AI_ORCHESTRA_OPENAI_EXECUTION_ENABLED=false
OPENAI_API_KEY=
