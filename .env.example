# Placeholder values only. Copy to a local ignored environment file.
APP_NAME=AI Orchestra
APP_VERSION=0.1.0
LOG_LEVEL=info
PORT=3000

# Generate local demonstration values with `npm run demo:setup`.
DEMO_USERNAME=judge-demo
DEMO_PASSWORD_HASH=replace-with-a-versioned-scrypt-hash
SESSION_SECRET=replace-with-at-least-32-random-bytes

# AO-007 live execution is off by default. Keep the key server-side.
OPENAI_API_KEY=replace-with-your-openai-api-key
AI_ORCHESTRA_LIVE_EXECUTION_ENABLED=false
AI_ORCHESTRA_RUN_TIMEOUT_MS=30000
AI_ORCHESTRA_MAX_TOTAL_TOKENS=12000
AI_ORCHESTRA_MAX_OUTPUT_TOKENS=2048
AI_ORCHESTRA_MAX_RUN_COST_USD=0.25
AI_ORCHESTRA_MAX_CONCURRENT_RUNS=2

# Reserved for later bounded issues; the AO-007 runtime never reads this value.
DATABASE_URL=file:./data/ai-orchestra.db
